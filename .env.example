# Trend Vision One API Configuration
# Copy this file to .env and fill in your values

# Your Trend Vision One API token
TVOne_API_KEY=your_api_key_here

# Regional API base URL (choose your region):
#   Global:        https://api.xdr.trendmicro.com
#   US:            https://api.xdr.trendmicro.com
#   EU:            https://api.eu.xdr.trendmicro.com
#   Japan:         https://api.jp.xdr.trendmicro.com
#   Australia:     https://api.au.xdr.trendmicro.com
#   India:         https://api.in.xdr.trendmicro.com
#   Singapore:     https://api.sg.xdr.trendmicro.com
TVOne_BASE_URL=https://api.xdr.trendmicro.com

# Optional: report output directory (default: ./output)
REPORT_OUTPUT_DIR=./output

# ── Web application settings (web/app.py) ─────────────────────────────────────
# MySQL/MariaDB connection string for the reporter portal
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/tv1reporter

# Random 32-character secret for JWT signing and flash message signing
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-secret

# Fernet symmetric key for encrypting API keys at rest
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=generate-with-python-m-cryptography-fernet-gen-key

# Bootstrap admin user (created on first startup if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_EMAIL=admin@localhost

# JWT expiry in minutes (default: 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480
